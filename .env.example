# GrowthPilot AI — Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env.local and fill in your real API keys/credentials.
# NEVER commit .env.local to version control.
# This file (.env.example) is safe to commit — it contains only placeholder values.

# ── AI Provider Configuration ────────────────────────────────────────────────
# Google Gemini setup
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Nodemailer SMTP Setup ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Notification Email Configuration ─────────────────────────────────────────
REVIEW_NOTIFY_EMAIL=

# ── Webhook / Integration URL ──────────────────────────────────────────────
N8N_REVIEW_WEBHOOK_URL=
